{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/status", "dest": "api/index.js" },
    { "src": "/run-task", "dest": "api/index.js" },
    { "src": "/results", "dest": "api/index.js" },
    { "src": "/results/(.*)", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
