{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/run-task-stream", "dest": "api/index.js" },
    { "src": "/run-task", "dest": "api/index.js" },
    { "src": "/status", "dest": "api/index.js" },
    { "src": "/results", "dest": "api/index.js" },
    { "src": "/results/(.*)", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "api/index.js" }
  ]
}
